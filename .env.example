# - `VITE_ENVIRONMENT_MODE=production|development|local`
# Use `production` for shipped builds (Coolify / static host). Use `local` for Vite dev only.
VITE_ENVIRONMENT_MODE=local

# API (required). Must point to Laravel API host (not frontend static host).
VITE_API_BASE_URL=http://localhost:8000/api/v1
# Production: https://api.gidira.tech/api/v1

# ─── Reverb / WebSocket (browser connects directly to the WS server) ──────────
# VITE_REVERB_APP_KEY MUST equal REVERB_APP_KEY in api + websocket services.
# Coolify: set these as Docker BUILD ARGS on the frontend service (see Dockerfile).
#
# Production:
#   VITE_REVERB_HOST=ws.gidira.tech
#   VITE_REVERB_PORT=443
#   VITE_REVERB_SCHEME=https
#
# Local (olabisiolai_websocket on host):
#   VITE_REVERB_HOST=localhost
#   VITE_REVERB_PORT=8080
#   VITE_REVERB_SCHEME=http
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

VITE_AUTH_STRATEGY=bearer_memory
VITE_BEARER_TOKEN_STORAGE=local
VITE_AUTH_ME_PATH=/auth/profile
VITE_AUTH_LOGOUT_PATH=/auth/logout

# Google Maps (optional for admin Locations)
# VITE_GOOGLE_MAPS_API_KEY=

# Payments (optional)
# VITE_FLUTTERWAVE_PUBLIC_KEY=
# VITE_PAYSTACK_PUBLIC_KEY=
