# - `VITE_ENVIRONMENT_MODE=production|development|local`
# Use `production` for shipped builds (Coolify / static host). Use `local` for Vite dev only.
VITE_ENVIRONMENT_MODE=local

# Optional env config:

# - `VITE_FAVICON_API_URL` (optional)
# - `VITE_FAVICON_RESPONSE_PATH` (optional, default: `data.favicon`)
# - `VITE_FAVICON_CACHE_TTL_MS` (optional)
# If `VITE_FAVICON_API_URL` is not set, system stays in manual/fallback mode.

# API (required). Must point to Laravel API host (not frontend static host).
# VITE_API_BASE_URL=https://olabisiolai.maktechlaravel.cloud/api/v1
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Laravel Reverb (real-time messaging). Must match backend REVERB_* values.
# ---------------------------------------------------------------------------
# REQUIRED for real-time (Echo + WebSockets). If either line is missing at Vite BUILD time,
# the production bundle will NOT open any wss:// connection â€” Network tab will show no WS.
# Coolify: set these on the FRONTEND service as build args / build env (see Dockerfile ARGs).
# ---------------------------------------------------------------------------
# Production: align with server `.env` from backend repo `Olabisiolai_Laravel12/.env.production.example` (not root `.env.example`).
# VITE_REVERB_APP_KEY must equal Laravel REVERB_APP_KEY (same string). If backend keys are empty or wrong host, WebSockets fail.
# VITE_REVERB_HOST: hostname only (no https://, no path). Must be the Laravel API host that
# serves WebSockets (nginx proxies /app â†’ Reverb). If the SPA is on another domain, still use
# the API hostname here â€” not the static frontend hostname.
# If VITE_REVERB_SCHEME is omitted, TLS follows VITE_API_BASE_URL (https API â†’ wss on port 443 unless VITE_REVERB_PORT is set).
# VITE_REVERB_APP_KEY=your-reverb-key
# VITE_REVERB_HOST=your-domain.example
# VITE_REVERB_PORT=443
# VITE_REVERB_SCHEME=https

# Production build (Coolify): set VITE_ENVIRONMENT_MODE=production and all VITE_* above
# as build arguments so the bundle points at the live API and Reverb.
# See `.env.production.example` for gidira.cloud template.
# VITE_API_BASE_URL=https://api.gidira.cloud/api/v1

# Google Maps (optional for admin Locations). Enable "Maps JavaScript API" + "Places API" in GCP; restrict key by HTTP referrer.
# Google Maps (street address autocomplete + admin map picker)
# VITE_GOOGLE_MAPS_API_KEY=
# Optional: use Places API (New) after enabling it in Google Cloud + referrer allowlist
# VITE_GOOGLE_PLACES_USE_NEW_API=false

VITE_AUTH_STRATEGY=bearer_memory

# Bearer token storage: local | session | memory
VITE_BEARER_TOKEN_STORAGE=local

VITE_AUTH_ME_PATH=/auth/profile

VITE_AUTH_LOGOUT_PATH=/auth/logout

# Payments (optional)
# Flutterwave Public Key for client-side checkout
# VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxx-X

# Paystack Public Key for client-side checkout
# VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Dev-only (do NOT ship): Flutterwave Secret Key for Vite dev proxy verify endpoint
# This is NOT exposed to the browser bundle because it does not start with VITE_.
# FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxx-X

# Roles:
# - single: user.role = "admin"
# - multi: user.roles = ["admin","seller"]
# VITE_ROLE_MODE=single
#
# Optional role policy overrides (JSON string). Example:
# VITE_ROLE_POLICY_JSON={"admin":{"fallback":"/admin/login","dashboard":"/admin"},"seller":{"fallback":"/seller/login","dashboard":"/seller"}}

# Login pages:
# - single: one login page for all roles (authed users redirect away from any login route)
# - multi: role-specific login pages (authed users redirect away only from their own role login page)
# VITE_LOGIN_MODE=single

# Logout:
# - single: always POST to VITE_AUTH_LOGOUT_PATH
# - multi: if role policy provides logoutPath for the current role, POST there; otherwise fallback to VITE_AUTH_LOGOUT_PATH
# VITE_LOGOUT_MODE=single

# Optional: automatic access-token refresh on 401 (requires API to return `refresh_token` on login
# and a refresh endpoint). If omitted or VITE_REFRESH_TOKEN_ENABLED is not true, refresh is disabled.
# VITE_REFRESH_TOKEN_ENABLED=false
# VITE_AUTH_REFRESH_PATH=/oauth/token
# VITE_REFRESH_TOKEN_BODY_KEY=refresh_token
